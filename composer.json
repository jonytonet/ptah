{
    "name": "jonytonet/ptah",
    "description": "Ptah — Laravel scaffolding generator. CRUD, DTOs, Repositories, Services, Livewire 4, Tailwind v4.",
    "version": "1.0.0",
    "type": "library",
    "keywords": ["laravel", "scaffolding", "crud", "generator", "livewire4", "tailwind"],
    "license": "MIT",
    "authors": [
        {
            "name": "jonytonet",
            "email": "jonytonet@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "livewire/livewire": "^4.0",
        "maatwebsite/excel": "^3.1",
        "barryvdh/laravel-dompdf": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "pragmarx/google2fa-laravel": "Required for 2FA via authenticator app (TOTP) — auth module",
        "bacon/bacon-qr-code": "Required for generating QR codes in TOTP setup — auth module",
        "prism-php/prism": "Required for the AI Agent module (conversational AI widget) — ai_agent module"
    },
    "autoload": {
        "psr-4": {
            "Ptah\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Ptah\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ptah\\PtahServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
